# ===== TELEGRAM =====
BOT_TOKEN=your_bot_token_from_botfather
BOT_USERNAME=lsjlove_bot
WEBHOOK_URL=https://lsjlove.duckdns.org
FRONT_END_URL=https://lsjlove.duckdns.org

# ===== MONGODB =====
MONGO_DB_CONNECTION_URI=mongodb://mongodb:27017
MONGO_DB_DATING_DATABASE=dating
MONGO_DB_USERS_COLLECTION=users
MONGO_DB_LIKES_COLLECTION=likes

# ===== S3 STORAGE (Backblaze B2) =====
AWS_ACCESS_KEY_ID=your_s3_access_key
AWS_SECRET_ACCESS_KEY=your_s3_secret_key
S3_BUCKET_NAME=lsjlove-media
# Для B2: явно задайте endpoint, чтобы избежать конфликта region/endpoint
S3_ENDPOINT_URL=https://s3.us-east-005.backblazeb2.com
S3_REGION_NAME=us-east-005

# ===== AI =====
OPENAI_API_KEY=your_openai_api_key

# ===== GEOCODER (Nominatim) =====
GEOCODER_URL=https://nominatim.openstreetmap.org
GEOCODE_CACHE_TTL_DAYS=90

# ===== PLATEGA (опционально) =====
PLATEGA_MERCHANT_ID=
PLATEGA_SECRET=
PLATEGA_PREMIUM_PRICE=299.0
PLATEGA_VIP_PRICE=799.0
PLATEGA_SUPERLIKE_PRICE=49.0
PLATEGA_ICEBREAKER_PACK_PRICE=49.0

# ===== TELEGRAM STARS PRICING =====
STARS_PREMIUM_MONTHLY=500
STARS_VIP_MONTHLY=1500
STARS_SUPERLIKE=50
STARS_BOOST=150
STARS_AI_PACK=200
STARS_ICEBREAKER_PACK=100

# ===== LIMITS =====
DAILY_LIKES_FREE=20
PLATEGA_SWIPE_PACK_40_PRICE=99.0
PLATEGA_SWIPE_PACK_80_PRICE=149.0

# ===== FEATURE FLAGS =====
ENABLE_WEBAPP=false
ENABLE_BOT_MATCH=true
ENABLE_SITE_AUTH_V2=true
ENABLE_STARS_IN_BOT=true
ICEBREAKER_FREE_TOTAL=5
ICEBREAKER_DAILY_PREMIUM=5
ICEBREAKER_DAILY_VIP=10

# ===== ADMIN (обязательно переопределить в проде!) =====
ADMIN_SECRET_KEY=your_secure_admin_secret
ADMIN_TELEGRAM_IDS=

# ===== APP =====
API_PORT=8000
DEBUG=false
# В проде: список доверенных доменов через запятую, например https://lsjlove.duckdns.org,https://app.example.com
CORS_ORIGINS=*
